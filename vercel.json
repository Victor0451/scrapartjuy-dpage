{
  "version": 2,
  "builds": [
    { "src": "api/guardar.js", "use": "@vercel/node" },
    { "src": "*.html",         "use": "@vercel/static" },
    { "src": "*.json",         "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/guardar",    "dest": "/api/guardar.js" },
    { "src": "/productos.json", "dest": "/productos.json" },
    { "src": "/admin",          "dest": "/admin.html" },
    { "src": "/(.*)",           "dest": "/index.html" }
  ]
}
